# Director 2.0 - API keys (set the ones you have; the router autodetects).
# NEVER commit a real .env.

# Anthropic (Claude) - https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI - https://platform.openai.com
OPENAI_API_KEY=

# xAI (Grok) - https://console.x.ai
XAI_API_KEY=

# OpenRouter (many models, OpenAI-compatible) - https://openrouter.ai
OPENROUTER_API_KEY=

# Optional overrides
# DIRECTOR_HOME=E:/director2-workspace      # workspace root (default: ~/.director2)
# DIRECTOR_BACKEND=anthropic                # force a backend: anthropic|openai|xai|openrouter|mock
# DIRECTOR_MODEL=claude-fable-5             # override the primary model id
# DIRECTOR_MAX_PARALLEL=4                   # max concurrent subagents
# DIRECTOR_LOG_LEVEL=INFO
